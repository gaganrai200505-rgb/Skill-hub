# Copy this file to .env and fill in your actual values

# Django Backend Settings
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database Configuration
# SQLite (default - no configuration needed)
# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@host:port/database_name

# CORS Settings (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.vercel.app

# Frontend API Base URL
REACT_APP_API_BASE=http://127.0.0.1:8000

# Render Production Settings
# (These are set in Render dashboard, not in .env file)
# SECRET_KEY=your-production-secret-key
# DEBUG=False
# DATABASE_URL=your-postgres-url
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://your-backend-domain.onrender.com
